{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Forge",
  "version": "1.0.0",
  "identifier": "com.audioforge.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Audio Forge",
        "width": 960,
        "height": 700,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
